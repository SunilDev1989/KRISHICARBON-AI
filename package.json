{
  "name": "krishicarbon-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:strict": "eslint src --ext .ts,.tsx --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build"
  },
  "vitest": {
    "environment": "node",
    "include": [
      "src/lib/__tests__/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "firebase": "^12.14.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "pdfjs-dist": "^6.0.227",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
