rules_version = '2';

// KrishiCarbon AI — Firestore Security Rules
// Principle: farmId-scoped isolation. Each anonymous session
// can only read/write its own farm data. No cross-farm access.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isValidFarmId(farmId) {
      // farmId must be a non-empty string of 8–64 safe characters
      return farmId is string
          && farmId.size() >= 8
          && farmId.size() <= 64
          && farmId.matches('^[a-zA-Z0-9_-]+$');
    }

    function hasRequiredEmissionFields(data) {
      return data.keys().hasAll(['farmId', 'timestamp', 'totalCO2e'])
          && data.totalCO2e is number
          && data.totalCO2e >= 0;
    }

    // ── Farm emissions ledger ─────────────────────────────────────────────
    // Path: /emissions/{farmId}/records/{recordId}
    match /emissions/{farmId}/records/{recordId} {

      // Anyone with the farmId can read their own records (session-scoped)
      allow read: if isValidFarmId(farmId);

      // Create: must supply required fields, farmId must match path
      allow create: if isValidFarmId(farmId)
                    && request.resource.data.farmId == farmId
                    && hasRequiredEmissionFields(request.resource.data)
                    && request.resource.data.timestamp == request.time;

      // Immutable ledger — no updates or deletes allowed
      allow update: if false;
      allow delete: if false;
    }

    // ── Farm profile (optional GPS, crop type preferences) ────────────────
    match /farms/{farmId} {
      allow read: if isValidFarmId(farmId);

      allow create, update: if isValidFarmId(farmId)
                             && request.resource.data.farmId == farmId
                             && request.resource.data.keys().hasAll(['farmId', 'updatedAt']);

      allow delete: if false;
    }

    // ── Deny all other paths by default ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
